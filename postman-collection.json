{
  "info": {
    "name": "Job Tracker API",
    "description": "API collection for Job Tracker application with authentication and application management endpoints. Uses HTTP-only cookies for authentication.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "userId", "value": "" },
    { "key": "applicationId", "value": "" }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check if the server is running"
          }
        },
        {
          "name": "Protected Route (Example)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/protected-route",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "protected-route"]
            },
            "description": "Example protected route that requires authentication via authMiddleware."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function() { pm.response.to.have.status(201); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data && jsonData.data.user) { pm.collectionVariables.set('userId', jsonData.data.user.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data && jsonData.data.user) { pm.collectionVariables.set('userId', jsonData.data.user.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "me"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Get All Applications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/applications",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "applications"]
            }
          }
        },
        {
          "name": "Create Application",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function() { pm.response.to.have.status(201); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data) { pm.collectionVariables.set('applicationId', jsonData.data.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"companyName\": \"Tech Corp\",\n    \"roleTitle\": \"Senior Software Engineer\",\n    \"status\": \"APPLIED\",\n    \"location\": \"San Francisco, CA\",\n    \"salaryMin\": 120000,\n    \"salaryMax\": 180000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/applications",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "applications"]
            }
          }
        },
        {
          "name": "Get Application by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/applications/:id",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "applications", ":id"],
              "variable": [{ "key": "id", "value": "{{applicationId}}" }]
            }
          }
        },
        {
          "name": "Update Application",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"roleTitle\": \"Lead Software Engineer\",\n    \"location\": \"Remote\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/applications/:id",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "applications", ":id"],
              "variable": [{ "key": "id", "value": "{{applicationId}}" }]
            }
          }
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"SCREENING\",\n    \"note\": \"Phone screen scheduled\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/applications/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "applications", ":id", "status"],
              "variable": [{ "key": "id", "value": "{{applicationId}}" }]
            }
          }
        },
        {
          "name": "Delete Application",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/v1/applications/:id",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "applications", ":id"],
              "variable": [{ "key": "id", "value": "{{applicationId}}" }]
            }
          }
        },
        {
          "name": "Get Application Activity",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/applications/:id/activity",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "applications", ":id", "activity"],
              "variable": [{ "key": "id", "value": "{{applicationId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "Get Job Hunt Statistics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/stats",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "stats"]
            }
          }
        }
      ]
    }
  ]
}
